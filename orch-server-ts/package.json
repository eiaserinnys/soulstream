{
  "name": "@soulstream/orch-server-ts",
  "version": "0.0.1",
  "private": true,
  "description": "Soulstream TypeScript orchestrator scaffold and contract parity harness.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts src/production_main.ts --format esm --target node20 --dts --clean",
    "start": "node dist/production_main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/websocket": "11.2.0",
    "@hocuspocus/extension-database": "3.4.4",
    "@hocuspocus/server": "3.4.4",
    "fastify": "^5.1.0",
    "google-auth-library": "10.9.0",
    "postgres": "3.4.9",
    "y-protocols": "1.0.6",
    "yjs": "13.6.27",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@hocuspocus/provider": "3.4.4",
    "@types/node": "^20.11.0",
    "@types/ws": "8.18.1",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "ws": "^8.18.0"
  }
}
