{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://soulstream.eiaserinnys.me/schemas/upstream.json",
  "title": "Soulstream Upstream Protocol",
  "description": "노드 ↔ 오케스트레이터 WebSocket 메시지 정본. 73개 $defs (wire 33 + SSE event 40). 출처: soul-server/upstream/protocol.py · adapter.py · event_relay.py · command_handler.py · claude_auth_handlers.py / orch-server/constants.py KNOWN_SSE_EVENT_TYPES L60-69 (실측 2026-05-16) + OpenAI Agents SDK parity (2026-05-21).",
  "$defs": {
    "NodeRegister": {
      "type": "object",
      "description": "노드→orch: 등록. soul-server/upstream/adapter.py:_build_registration_msg L197-247.",
      "required": ["type", "node_id"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "node_register" },
        "node_id": { "type": "string" },
        "host": { "type": "string" },
        "port": { "type": "integer" },
        "capabilities": {
          "type": "object",
          "description": "노드 자체 가용성 정보. 예: {max_concurrent: 5}",
          "additionalProperties": true
        },
        "supported_backends": {
          "type": "array",
          "description": "이 노드가 지원하는 백엔드 식별자. 옵션 D — Codex/Claude 라우팅 분기.",
          "items": { "type": "string" },
          "default": ["claude"]
        },
        "agents": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "backend": { "type": "string", "default": "claude" },
              "portrait_url": { "type": "string" },
              "max_turns": { "type": ["integer", "null"] },
              "portrait_b64": { "type": "string" }
            }
          }
        },
        "user": {
          "type": "object",
          "description": "선택. 노드 사용자 프로필 (name, hasPortrait, portrait_b64).",
          "additionalProperties": true
        }
      }
    },
    "SessionCreated": {
      "type": "object",
      "description": "노드→orch: 세션 생성 응답 또는 broadcast. command_handler.py L220-228 + event_relay.py L119-133.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "session_created" },
        "agentSessionId": { "type": "string" },
        "requestId": { "type": "string" },
        "session": {
          "type": "object",
          "description": "broadcast 경로에서 송신되는 세션 정보 (to_session_info 결과).",
          "additionalProperties": true
        },
        "folderId": { "type": ["string", "null"] },
        "caller_source": {
          "type": "object",
          "description": "agent caller_info 흐름 보존 (R-2 fix, atom 0499ee7b).",
          "additionalProperties": true
        }
      }
    },
    "SessionEventEnvelope": {
      "type": "object",
      "description": "노드→orch: SSE 이벤트 wrapper. event_relay.py:relay_events L175-179. event.event 안에 SSEEvent* 중 하나가 packed.",
      "required": ["type", "agentSessionId", "event"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "event" },
        "agentSessionId": { "type": "string" },
        "session_id": {
          "type": "string",
          "description": "구버전 호환 — 신규 코드는 agentSessionId 사용."
        },
        "event": {
          "description": "SSE event payload. KNOWN_SSE_EVENT_TYPES 중 하나 (orch-server/constants.py L59-69).",
          "oneOf": [
            { "$ref": "#/$defs/SSEEventInit" },
            { "$ref": "#/$defs/SSEEventReconnected" },
            { "$ref": "#/$defs/SSEEventProgress" },
            { "$ref": "#/$defs/SSEEventMemory" },
            { "$ref": "#/$defs/SSEEventSession" },
            { "$ref": "#/$defs/SSEEventInterventionSent" },
            { "$ref": "#/$defs/SSEEventUserMessage" },
            { "$ref": "#/$defs/SSEEventAssistantMessage" },
            { "$ref": "#/$defs/SSEEventInputRequest" },
            { "$ref": "#/$defs/SSEEventInputRequestExpired" },
            { "$ref": "#/$defs/SSEEventInputRequestResponded" },
            { "$ref": "#/$defs/SSEEventDebug" },
            { "$ref": "#/$defs/SSEEventComplete" },
            { "$ref": "#/$defs/SSEEventError" },
            { "$ref": "#/$defs/SSEEventCredentialAlert" },
            { "$ref": "#/$defs/SSEEventThinking" },
            { "$ref": "#/$defs/SSEEventTextStart" },
            { "$ref": "#/$defs/SSEEventTextDelta" },
            { "$ref": "#/$defs/SSEEventTextEnd" },
            { "$ref": "#/$defs/SSEEventToolStart" },
            { "$ref": "#/$defs/SSEEventToolResult" },
            { "$ref": "#/$defs/SSEEventAgentUpdated" },
            { "$ref": "#/$defs/SSEEventHandoffRequested" },
            { "$ref": "#/$defs/SSEEventHandoffOccurred" },
            { "$ref": "#/$defs/SSEEventToolApprovalRequested" },
            { "$ref": "#/$defs/SSEEventToolApprovalResolved" },
            { "$ref": "#/$defs/SSEEventGuardrailTripwire" },
            { "$ref": "#/$defs/SSEEventRealtimeStatus" },
            { "$ref": "#/$defs/SSEEventRealtimeTranscript" },
            { "$ref": "#/$defs/SSEEventResult" },
            { "$ref": "#/$defs/SSEEventPromptSuggestion" },
            { "$ref": "#/$defs/SSEEventSubagentStart" },
            { "$ref": "#/$defs/SSEEventSubagentStop" },
            { "$ref": "#/$defs/SSEEventContextUsage" },
            { "$ref": "#/$defs/SSEEventCompact" },
            { "$ref": "#/$defs/SSEEventReconnect" },
            { "$ref": "#/$defs/SSEEventHistorySync" },
            { "$ref": "#/$defs/SSEEventMetadataUpdated" },
            { "$ref": "#/$defs/SSEEventAssistantError" },
            { "$ref": "#/$defs/SSEEventAwaySummary" }
          ]
        }
      }
    },
    "SessionsUpdate": {
      "type": "object",
      "description": "노드→orch: 전체 세션 목록 dump. adapter.py:_send_initial_sessions L313-325, command_handler.py:_handle_list_sessions L299-307.",
      "required": ["type", "sessions"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "sessions_update" },
        "sessions": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "total": { "type": "integer" },
        "requestId": { "type": "string" }
      }
    },
    "HealthStatus": {
      "type": "object",
      "description": "노드→orch: 헬스 응답. command_handler.py:_handle_health_check L309-317.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "health_status" },
        "runners": { "type": "object", "additionalProperties": true },
        "node_id": { "type": "string" },
        "requestId": { "type": "string" }
      }
    },
    "SessionUpdated": {
      "type": "object",
      "description": "노드→orch: 세션 상태 변경 broadcast. event_relay.py:_dispatch_broadcast_event L134-138. broadcaster 이벤트 dict가 그대로 spread되므로 페이로드는 inline 확장 가능.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "session_updated" },
        "agent_session_id": { "type": "string" },
        "agentSessionId": { "type": "string" }
      }
    },
    "SessionDeleted": {
      "type": "object",
      "description": "노드→orch: 세션 삭제 broadcast. event_relay.py L139-143.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "session_deleted" },
        "agent_session_id": { "type": "string" },
        "agentSessionId": { "type": "string" }
      }
    },
    "ErrorMessage": {
      "type": "object",
      "description": "노드→orch: 에러 응답. adapter.py:_send_error L334-346.",
      "required": ["type", "message"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "error" },
        "message": { "type": "string" },
        "requestId": { "type": "string" },
        "request_id": {
          "type": "string",
          "description": "구버전 snake_case 호환 필드."
        },
        "command_type": { "type": "string" }
      }
    },
    "InterveneAck": {
      "type": "object",
      "description": "노드→orch: intervene 명령 ACK. command_handler.py:_handle_intervene L249-254. orch _send_command Future 매칭에 사용.",
      "required": ["type", "requestId"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "intervene_ack" },
        "requestId": { "type": "string" },
        "status": { "type": "string", "enum": ["ok"] }
      }
    },
    "InterruptSessionAck": {
      "type": "object",
      "description": "노드→orch: interrupt_session 명령 ACK. command_handler.py:_handle_interrupt_session + TS dispatcher.handleInterruptSession.",
      "required": ["type", "requestId", "status"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "interrupt_session_ack" },
        "requestId": { "type": "string" },
        "status": { "type": "string", "enum": ["ok"] },
        "interrupted": { "type": "boolean" },
        "agentSessionId": { "type": "string" }
      }
    },
    "RespondAck": {
      "type": "object",
      "description": "노드→orch: respond 명령 ACK. TS Claude AskUserQuestion 응답 전달 결과. 실패도 ACK로 반환하여 orch command timeout을 막는다.",
      "required": ["type", "requestId", "status"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "respond_ack" },
        "requestId": { "type": "string" },
        "inputRequestId": { "type": "string" },
        "status": { "type": "string", "enum": ["ok", "error"] },
        "delivered": { "type": "boolean" },
        "eventId": { "type": "integer" },
        "code": { "type": "string" },
        "message": { "type": "string" },
        "backend": { "type": "string" },
        "taskStatus": { "type": "string" }
      }
    },
    "ToolApprovalAck": {
      "type": "object",
      "description": "노드→orch: approve_tool/reject_tool ACK. OpenAI Agents SDK tool approval 결과. 실패도 ACK로 반환하여 orch command timeout을 막는다.",
      "required": ["type", "requestId", "status"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "tool_approval_ack" },
        "requestId": { "type": "string" },
        "approvalId": { "type": "string" },
        "decision": { "type": "string", "enum": ["approved", "rejected"] },
        "status": { "type": "string", "enum": ["ok", "error"] },
        "delivered": { "type": "boolean" },
        "eventId": { "type": "integer" },
        "code": { "type": "string" },
        "message": { "type": "string" },
        "backend": { "type": "string" },
        "taskStatus": { "type": "string" }
      }
    },
    "RealtimeCallCreated": {
      "type": "object",
      "description": "노드→orch: realtime_create_call ACK. soul-app WebRTC offer에 대한 OpenAI Realtime SDP answer.",
      "required": ["type", "requestId", "status"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "realtime_call_created" },
        "requestId": { "type": "string" },
        "agentSessionId": { "type": "string" },
        "status": { "type": "string", "enum": ["ok", "error"] },
        "callId": { "type": "string" },
        "answerSdp": { "type": "string" },
        "eventId": { "type": "integer" },
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    },
    "RealtimeEventAck": {
      "type": "object",
      "description": "노드→orch: realtime_event ACK. soul-app data-channel event persistence/relay result.",
      "required": ["type", "requestId", "status"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "realtime_event_ack" },
        "requestId": { "type": "string" },
        "agentSessionId": { "type": "string" },
        "status": { "type": "string", "enum": ["ok", "error"] },
        "normalizedType": { "type": "string" },
        "eventId": { "type": "integer" },
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    },
    "RealtimeToolApprovalAck": {
      "type": "object",
      "description": "노드→orch: realtime_resolve_tool_approval ACK. Persisted resolution plus app data-channel decision event.",
      "required": ["type", "requestId", "status"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "realtime_tool_approval_ack" },
        "requestId": { "type": "string" },
        "agentSessionId": { "type": "string" },
        "approvalId": { "type": "string" },
        "decision": { "type": "string", "enum": ["approved", "rejected"] },
        "status": { "type": "string", "enum": ["ok", "error"] },
        "dataChannelEvent": { "type": "object", "additionalProperties": true },
        "eventId": { "type": "integer" },
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    },
    "CreateSession": {
      "type": "object",
      "description": "orch→노드: 세션 생성. protocol.py:CreateSessionCmd L15-27 + 실측 caller_info 키.",
      "required": ["type", "prompt"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "create_session" },
        "prompt": { "type": "string" },
        "profile": { "type": "string" },
        "request_id": { "type": "string" },
        "requestId": { "type": "string" },
        "folderId": { "type": ["string", "null"] },
        "allowed_tools": { "type": "array", "items": { "type": "string" } },
        "disallowed_tools": { "type": "array", "items": { "type": "string" } },
        "use_mcp": { "type": "boolean" },
        "context": { "type": "object", "additionalProperties": true },
        "context_items": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "extra_context_items": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "caller_info": { "type": "object", "additionalProperties": true },
        "reasoningEffort": {
          "type": "string",
          "enum": ["minimal", "low", "medium", "high", "xhigh"],
          "description": "Codex-only reasoning effort. Missing means codex adapter default xhigh."
        }
      }
    },
    "Intervene": {
      "type": "object",
      "description": "orch→노드: 개입 명령. protocol.py:InterveneCmd L30-34 + command_handler.py L237-243 attachment_paths/caller_info.",
      "required": ["type", "agentSessionId", "text"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "intervene" },
        "agentSessionId": { "type": "string" },
        "session_id": {
          "type": "string",
          "description": "구버전 호환 — 신규 코드는 agentSessionId 사용."
        },
        "text": { "type": "string" },
        "user": { "type": "string" },
        "requestId": { "type": "string" },
        "attachment_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "caller_info": { "type": "object", "additionalProperties": true }
      }
    },
    "InterruptSession": {
      "type": "object",
      "description": "orch→노드: 진행 중인 세션 turn 중단 명령.",
      "required": ["type", "agentSessionId"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "interrupt_session" },
        "agentSessionId": { "type": "string" },
        "session_id": {
          "type": "string",
          "description": "구버전 호환 — 신규 코드는 agentSessionId 사용."
        },
        "requestId": { "type": "string" },
        "request_id": { "type": "string" }
      }
    },
    "Respond": {
      "type": "object",
      "description": "orch→노드: AskUserQuestion 응답. protocol.py:RespondCmd L37-48 + command_handler.py L271-297.",
      "required": ["type", "agentSessionId", "answers"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "respond" },
        "agentSessionId": { "type": "string" },
        "session_id": { "type": "string", "description": "구버전 호환." },
        "inputRequestId": { "type": "string" },
        "request_id": { "type": "string", "description": "구버전 호환." },
        "answers": { "type": "object", "additionalProperties": true },
        "requestId": { "type": "string" }
      }
    },
    "ApproveTool": {
      "type": "object",
      "description": "orch→노드: OpenAI Agents SDK tool approval 승인.",
      "required": ["type", "agentSessionId", "approvalId"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "approve_tool" },
        "agentSessionId": { "type": "string" },
        "session_id": { "type": "string", "description": "구버전 호환." },
        "approvalId": { "type": "string" },
        "approval_id": { "type": "string", "description": "구버전 호환." },
        "requestId": { "type": "string" },
        "request_id": { "type": "string" },
        "alwaysApprove": { "type": "boolean" }
      }
    },
    "RejectTool": {
      "type": "object",
      "description": "orch→노드: OpenAI Agents SDK tool approval 거부.",
      "required": ["type", "agentSessionId", "approvalId"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "reject_tool" },
        "agentSessionId": { "type": "string" },
        "session_id": { "type": "string", "description": "구버전 호환." },
        "approvalId": { "type": "string" },
        "approval_id": { "type": "string", "description": "구버전 호환." },
        "requestId": { "type": "string" },
        "request_id": { "type": "string" },
        "message": { "type": "string" },
        "alwaysReject": { "type": "boolean" }
      }
    },
    "RealtimeCreateCall": {
      "type": "object",
      "description": "orch→노드: soul-app WebRTC offer를 OpenAI Realtime call로 broker.",
      "required": ["type", "agentSessionId", "offerSdp"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "realtime_create_call" },
        "agentSessionId": { "type": "string" },
        "session_id": { "type": "string" },
        "offerSdp": { "type": "string" },
        "offer_sdp": { "type": "string" },
        "model": { "type": ["string", "null"] },
        "voice": { "type": ["string", "null"] },
        "instructions": { "type": ["string", "null"] },
        "requestId": { "type": "string" },
        "request_id": { "type": "string" }
      }
    },
    "RealtimeEvent": {
      "type": "object",
      "description": "orch→노드: soul-app Realtime data-channel event를 persistence/relay 경로로 전달.",
      "required": ["type", "agentSessionId", "event"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "realtime_event" },
        "agentSessionId": { "type": "string" },
        "session_id": { "type": "string" },
        "event": { "type": "object", "additionalProperties": true },
        "callId": { "type": ["string", "null"] },
        "call_id": { "type": ["string", "null"] },
        "requestId": { "type": "string" },
        "request_id": { "type": "string" }
      }
    },
    "RealtimeResolveToolApproval": {
      "type": "object",
      "description": "orch→노드: realtime voice 중 발생한 tool approval decision을 영속화.",
      "required": ["type", "agentSessionId", "approvalId", "decision"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "realtime_resolve_tool_approval" },
        "agentSessionId": { "type": "string" },
        "session_id": { "type": "string" },
        "approvalId": { "type": "string" },
        "approval_id": { "type": "string" },
        "decision": { "type": "string", "enum": ["approved", "rejected"] },
        "message": { "type": "string" },
        "source": { "type": "string", "enum": ["tap", "voice"] },
        "callId": { "type": ["string", "null"] },
        "call_id": { "type": ["string", "null"] },
        "requestId": { "type": "string" },
        "request_id": { "type": "string" }
      }
    },
    "ListSessions": {
      "type": "object",
      "description": "orch→노드: 세션 목록 조회. protocol.py:ListSessionsCmd L51-53.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "list_sessions" },
        "request_id": { "type": "string" },
        "requestId": { "type": "string" }
      }
    },
    "PlanAgentProfileUpdate": {
      "type": "object",
      "description": "orch→노드: agents.yaml 단일 agent profile 교체 계획(diff) read-only 조회. 응답도 동일 type에 ok/config_path/changed/diff/comment_preservation을 추가한다.",
      "required": ["type", "profile"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "plan_agent_profile_update" },
        "request_id": { "type": "string" },
        "requestId": { "type": "string" },
        "profile": {
          "type": "object",
          "additionalProperties": true
        },
        "create_if_missing": { "type": "boolean", "default": false },
        "createIfMissing": { "type": "boolean", "default": false },
        "ok": {
          "type": "boolean",
          "description": "응답에만 존재."
        },
        "config_path": {
          "type": "string",
          "description": "응답에만 존재."
        },
        "changed": {
          "type": "boolean",
          "description": "응답에만 존재."
        },
        "diff": {
          "type": "string",
          "description": "응답에만 존재."
        },
        "snapshot_root": {
          "type": "string",
          "description": "응답에만 존재. read-only plan은 snapshot 파일을 만들지 않는다."
        },
        "comment_preservation": {
          "type": "string",
          "enum": ["not_preserved"],
          "description": "응답에만 존재."
        }
      }
    },
    "HealthCheck": {
      "type": "object",
      "description": "orch→노드: 헬스체크. protocol.py:HealthCheckCmd L56-58.",
