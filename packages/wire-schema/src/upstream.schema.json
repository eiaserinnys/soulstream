{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://soulstream.eiaserinnys.me/schemas/upstream.json",
  "title": "Soulstream Upstream Protocol",
  "description": "노드 ↔ 오케스트레이터 WebSocket 메시지 정본. 48개 $defs (wire 20 + SSE event 28). 출처: soul-server/upstream/protocol.py · adapter.py · event_relay.py · command_handler.py · claude_auth_handlers.py / orch-server/constants.py KNOWN_SSE_EVENT_TYPES L60-69 (실측 2026-05-16).",
  "$defs": {
    "NodeRegister": {
      "type": "object",
      "description": "노드→orch: 등록. soul-server/upstream/adapter.py:_build_registration_msg L197-247.",
      "required": ["type", "node_id"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "node_register" },
        "node_id": { "type": "string" },
        "host": { "type": "string" },
        "port": { "type": "integer" },
        "capabilities": {
          "type": "object",
          "description": "노드 자체 가용성 정보. 예: {max_concurrent: 5}",
          "additionalProperties": true
        },
        "supported_backends": {
          "type": "array",
          "description": "이 노드가 지원하는 백엔드 식별자. 옵션 D — Codex/Claude 라우팅 분기.",
          "items": { "type": "string" },
          "default": ["claude"]
        },
        "agents": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "backend": { "type": "string", "default": "claude" },
              "portrait_url": { "type": "string" },
              "max_turns": { "type": ["integer", "null"] },
              "portrait_b64": { "type": "string" }
            }
          }
        },
        "user": {
          "type": "object",
          "description": "선택. 노드 사용자 프로필 (name, hasPortrait, portrait_b64).",
          "additionalProperties": true
        }
      }
    },
    "SessionCreated": {
      "type": "object",
      "description": "노드→orch: 세션 생성 응답 또는 broadcast. command_handler.py L220-228 + event_relay.py L119-133.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "session_created" },
        "agentSessionId": { "type": "string" },
        "requestId": { "type": "string" },
        "session": {
          "type": "object",
          "description": "broadcast 경로에서 송신되는 세션 정보 (to_session_info 결과).",
          "additionalProperties": true
        },
        "folderId": { "type": ["string", "null"] },
        "caller_source": {
          "type": "object",
          "description": "agent caller_info 흐름 보존 (R-2 fix, atom 0499ee7b).",
          "additionalProperties": true
        }
      }
    },
    "SessionEventEnvelope": {
      "type": "object",
      "description": "노드→orch: SSE 이벤트 wrapper. event_relay.py:relay_events L175-179. event.event 안에 SSEEvent* 중 하나가 packed.",
      "required": ["type", "agentSessionId", "event"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "event" },
        "agentSessionId": { "type": "string" },
        "session_id": {
          "type": "string",
          "description": "구버전 호환 — 신규 코드는 agentSessionId 사용."
        },
        "event": {
          "description": "SSE event payload. KNOWN_SSE_EVENT_TYPES 27종 중 하나 (orch-server/constants.py L59-69).",
          "oneOf": [
            { "$ref": "#/$defs/SSEEventInit" },
            { "$ref": "#/$defs/SSEEventReconnected" },
            { "$ref": "#/$defs/SSEEventProgress" },
            { "$ref": "#/$defs/SSEEventMemory" },
            { "$ref": "#/$defs/SSEEventSession" },
            { "$ref": "#/$defs/SSEEventInterventionSent" },
            { "$ref": "#/$defs/SSEEventUserMessage" },
            { "$ref": "#/$defs/SSEEventAssistantMessage" },
            { "$ref": "#/$defs/SSEEventInputRequest" },
            { "$ref": "#/$defs/SSEEventInputRequestExpired" },
            { "$ref": "#/$defs/SSEEventInputRequestResponded" },
            { "$ref": "#/$defs/SSEEventDebug" },
            { "$ref": "#/$defs/SSEEventComplete" },
            { "$ref": "#/$defs/SSEEventError" },
            { "$ref": "#/$defs/SSEEventThinking" },
            { "$ref": "#/$defs/SSEEventTextStart" },
            { "$ref": "#/$defs/SSEEventTextDelta" },
            { "$ref": "#/$defs/SSEEventTextEnd" },
            { "$ref": "#/$defs/SSEEventToolStart" },
            { "$ref": "#/$defs/SSEEventToolResult" },
            { "$ref": "#/$defs/SSEEventResult" },
            { "$ref": "#/$defs/SSEEventSubagentStart" },
            { "$ref": "#/$defs/SSEEventSubagentStop" },
            { "$ref": "#/$defs/SSEEventContextUsage" },
            { "$ref": "#/$defs/SSEEventCompact" },
            { "$ref": "#/$defs/SSEEventReconnect" },
            { "$ref": "#/$defs/SSEEventHistorySync" },
            { "$ref": "#/$defs/SSEEventMetadataUpdated" }
          ]
        }
      }
    },
    "SessionsUpdate": {
      "type": "object",
      "description": "노드→orch: 전체 세션 목록 dump. adapter.py:_send_initial_sessions L313-325, command_handler.py:_handle_list_sessions L299-307.",
      "required": ["type", "sessions"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "sessions_update" },
        "sessions": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "total": { "type": "integer" },
        "requestId": { "type": "string" }
      }
    },
    "HealthStatus": {
      "type": "object",
      "description": "노드→orch: 헬스 응답. command_handler.py:_handle_health_check L309-317.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "health_status" },
        "runners": { "type": "object", "additionalProperties": true },
        "node_id": { "type": "string" },
        "requestId": { "type": "string" }
      }
    },
    "SessionUpdated": {
      "type": "object",
      "description": "노드→orch: 세션 상태 변경 broadcast. event_relay.py:_dispatch_broadcast_event L134-138. broadcaster 이벤트 dict가 그대로 spread되므로 페이로드는 inline 확장 가능.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "session_updated" },
        "agent_session_id": { "type": "string" },
        "agentSessionId": { "type": "string" }
      }
    },
    "SessionDeleted": {
      "type": "object",
      "description": "노드→orch: 세션 삭제 broadcast. event_relay.py L139-143.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "session_deleted" },
        "agent_session_id": { "type": "string" },
        "agentSessionId": { "type": "string" }
      }
    },
    "ErrorMessage": {
      "type": "object",
      "description": "노드→orch: 에러 응답. adapter.py:_send_error L334-346.",
      "required": ["type", "message"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "error" },
        "message": { "type": "string" },
        "requestId": { "type": "string" },
        "request_id": {
          "type": "string",
          "description": "구버전 snake_case 호환 필드."
        },
        "command_type": { "type": "string" }
      }
    },
    "InterveneAck": {
      "type": "object",
      "description": "노드→orch: intervene 명령 ACK. command_handler.py:_handle_intervene L249-254. orch _send_command Future 매칭에 사용.",
      "required": ["type", "requestId"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "intervene_ack" },
        "requestId": { "type": "string" },
        "status": { "type": "string", "enum": ["ok"] }
      }
    },
    "CreateSession": {
      "type": "object",
      "description": "orch→노드: 세션 생성. protocol.py:CreateSessionCmd L15-27 + 실측 caller_info 키.",
      "required": ["type", "prompt"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "create_session" },
        "prompt": { "type": "string" },
        "profile": { "type": "string" },
        "request_id": { "type": "string" },
        "requestId": { "type": "string" },
        "folderId": { "type": ["string", "null"] },
        "allowed_tools": { "type": "array", "items": { "type": "string" } },
        "disallowed_tools": { "type": "array", "items": { "type": "string" } },
        "use_mcp": { "type": "boolean" },
        "context": { "type": "object", "additionalProperties": true },
        "context_items": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "extra_context_items": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "caller_info": { "type": "object", "additionalProperties": true },
        "reasoningEffort": {
          "type": "string",
          "enum": ["minimal", "low", "medium", "high", "xhigh"],
          "description": "Codex-only reasoning effort. Missing means codex adapter default xhigh."
        }
      }
    },
    "Intervene": {
      "type": "object",
      "description": "orch→노드: 개입 명령. protocol.py:InterveneCmd L30-34 + command_handler.py L237-243 attachment_paths/caller_info.",
      "required": ["type", "agentSessionId", "text"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "intervene" },
        "agentSessionId": { "type": "string" },
        "session_id": {
          "type": "string",
          "description": "구버전 호환 — 신규 코드는 agentSessionId 사용."
        },
        "text": { "type": "string" },
        "user": { "type": "string" },
        "requestId": { "type": "string" },
        "attachment_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "caller_info": { "type": "object", "additionalProperties": true }
      }
    },
    "Respond": {
      "type": "object",
      "description": "orch→노드: AskUserQuestion 응답. protocol.py:RespondCmd L37-48 + command_handler.py L271-297.",
      "required": ["type", "agentSessionId", "answers"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "respond" },
        "agentSessionId": { "type": "string" },
        "session_id": { "type": "string", "description": "구버전 호환." },
        "inputRequestId": { "type": "string" },
        "request_id": { "type": "string", "description": "구버전 호환." },
        "answers": { "type": "object", "additionalProperties": true },
        "requestId": { "type": "string" }
      }
    },
    "ListSessions": {
      "type": "object",
      "description": "orch→노드: 세션 목록 조회. protocol.py:ListSessionsCmd L51-53.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "list_sessions" },
        "request_id": { "type": "string" },
        "requestId": { "type": "string" }
      }
    },
    "HealthCheck": {
      "type": "object",
      "description": "orch→노드: 헬스체크. protocol.py:HealthCheckCmd L56-58.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "health_check" },
        "request_id": { "type": "string" },
        "requestId": { "type": "string" }
      }
    },
    "SubscribeEvents": {
      "type": "object",
      "description": "orch→노드: 라이브 이벤트 구독. protocol.py:SubscribeEventsCmd L61-65 + command_handler.py L319-333.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "subscribe_events" },
        "session_id": { "type": "string" },
        "agentSessionId": { "type": "string" },
        "after_id": { "type": "integer", "default": 0 },
        "request_id": { "type": "string" },
        "requestId": { "type": "string" },
        "subscribeId": { "type": "string" }
      }
    },
    "ClaudeAuthStatus": {
      "type": "object",
      "description": "orch→노드: Claude OAuth 토큰 존재 여부 조회. claude_auth_handlers.py:handle_auth_status L26-33. 응답도 동일 type, has_token 추가.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "claude_auth_status" },
        "requestId": { "type": "string" },
        "has_token": {
          "type": "boolean",
          "description": "응답에만 존재. true이면 토큰 저장됨."
        }
      }
    },
    "ClaudeAuthSetToken": {
      "type": "object",
      "description": "orch→노드: Claude OAuth 토큰 설정. claude_auth_handlers.py:handle_auth_set_token L36-65.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "claude_auth_set_token" },
        "requestId": { "type": "string" },
        "token": { "type": "string" },
        "refresh_token": { "type": "string" },
        "expires_in": { "type": ["integer", "null"] },
        "scope": { "type": "string" },
        "success": {
          "type": "boolean",
          "description": "응답에만 존재."
        }
      }
    },
    "ClaudeAuthDeleteToken": {
      "type": "object",
      "description": "orch→노드: Claude OAuth 토큰 삭제. claude_auth_handlers.py:handle_auth_delete_token L68-76.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "claude_auth_delete_token" },
        "requestId": { "type": "string" },
        "success": {
          "type": "boolean",
          "description": "응답에만 존재."
        }
      }
    },
    "ClaudeAuthGetUsage": {
      "type": "object",
      "description": "orch→노드: Anthropic OAuth usage 조회. claude_auth_handlers.py:handle_auth_api_request L79-119 (URL=ANTHROPIC_USAGE_URL).",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "claude_auth_get_usage" },
        "requestId": { "type": "string" },
        "success": { "type": "boolean", "description": "응답에만 존재." },
        "error": { "type": "string", "description": "실패 응답에만 존재." },
        "data": {
          "type": "object",
          "description": "성공 응답: Anthropic API JSON.",
          "additionalProperties": true
        }
      }
    },
    "ClaudeAuthGetProfile": {
      "type": "object",
      "description": "orch→노드: Anthropic OAuth profile 조회. claude_auth_handlers.py:handle_auth_api_request L79-119 (URL=ANTHROPIC_PROFILE_URL).",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": { "const": "claude_auth_get_profile" },
        "requestId": { "type": "string" },
        "success": { "type": "boolean", "description": "응답에만 존재." },
        "error": { "type": "string", "description": "실패 응답에만 존재." },
        "data": {
          "type": "object",
          "description": "성공 응답: Anthropic API JSON.",
          "additionalProperties": true
        }
      }
    },
    "SSEEventInit": {
      "type": "object",
      "description": "SSE: 세션 스트림 초기화. event 메시지의 event 키 안에 packed.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": { "type": { "const": "init" } }
    },
    "SSEEventReconnected": {
      "type": "object",
      "description": "SSE: 재연결 안내.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": { "type": { "const": "reconnected" } }
    },
    "SSEEventProgress": {
      "type": "object",
      "description": "SSE: 진행 상태.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": { "type": { "const": "progress" } }
    },
    "SSEEventMemory": {
      "type": "object",
      "description": "SSE: memory 이벤트.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": { "type": { "const": "memory" } }
    },
    "SSEEventSession": {
      "type": "object",
      "description": "SSE: 세션 메타.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": { "type": { "const": "session" } }
    },
    "SSEEventInterventionSent": {
      "type": "object",
      "description": "SSE: 사용자 개입 메시지 발신.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": { "type": { "const": "intervention_sent" } }
    },
    "SSEEventUserMessage": {
      "type": "object",
      "description": "SSE: 사용자 메시지.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": { "type": { "const": "user_message" } }
    },
    "SSEEventAssistantMessage": {
      "type": "object",
      "description": "SSE: 어시스턴트 메시지 완료본.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": { "type": { "const": "assistant_message" } }
    },
    "SSEEventInputRequest": {
      "type": "object",
      "description": "SSE: AskUserQuestion 요청. 별도 wire 메시지로도 forwarding (constants.py EVT_INPUT_REQUEST L41).",
      "required": ["type"],
      "additionalProperties": true,
      "properties": { "type": { "const": "input_request" } }
    },
    "SSEEventInputRequestExpired": {
      "type": "object",
      "description": "SSE: input_request 만료.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": { "type": { "const": "input_request_expired" } }
    },
    "SSEEventInputRequestResponded": {
      "type": "object",
      "description": "SSE: input_request 응답 도착.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": { "type": { "const": "input_request_responded" } }
    },
    "SSEEventDebug": {
      "type": "object",
      "description": "SSE: debug 로그.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": { "type": { "const": "debug" } }
    },
    "SSEEventComplete": {
      "type": "object",
      "description": "SSE: 턴 종료.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": { "type": { "const": "complete" } }
    },
    "SSEEventError": {
      "type": "object",
      "description": "SSE: 에러.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": { "type": { "const": "error" } }
    },
    "SSEEventThinking": {
      "type": "object",
      "description": "SSE: thinking 블록.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": { "type": { "const": "thinking" } }
    },
    "SSEEventTextStart": {
      "type": "object",
      "description": "SSE: text 블록 시작.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": { "type": { "const": "text_start" } }
    },
    "SSEEventTextDelta": {
      "type": "object",
      "description": "SSE: text delta.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": { "type": { "const": "text_delta" } }
    },
    "SSEEventTextEnd": {
      "type": "object",
      "description": "SSE: text 블록 종료.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": { "type": { "const": "text_end" } }
    },
    "SSEEventToolStart": {
      "type": "object",
      "description": "SSE: tool 호출 시작.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": { "type": { "const": "tool_start" } }
    },
    "SSEEventToolResult": {
      "type": "object",
      "description": "SSE: tool 호출 결과.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": { "type": { "const": "tool_result" } }
    },
    "SSEEventResult": {
      "type": "object",
      "description": "SSE: 최종 result.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": { "type": { "const": "result" } }
    },
    "SSEEventSubagentStart": {
      "type": "object",
      "description": "SSE: subagent 시작.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": { "type": { "const": "subagent_start" } }
    },
    "SSEEventSubagentStop": {
      "type": "object",
      "description": "SSE: subagent 종료.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": { "type": { "const": "subagent_stop" } }
    },
    "SSEEventContextUsage": {
      "type": "object",
      "description": "SSE: 컨텍스트 사용량.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": { "type": { "const": "context_usage" } }
    },
    "SSEEventCompact": {
      "type": "object",
      "description": "SSE: compact 안내.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": { "type": { "const": "compact" } }
    },
    "SSEEventReconnect": {
      "type": "object",
      "description": "SSE: 클라이언트에 재연결 권고.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": { "type": { "const": "reconnect" } }
    },
    "SSEEventHistorySync": {
      "type": "object",
      "description": "SSE: 과거 이력 동기화.",
      "required": ["type"],
      "additionalProperties": true,
      "properties": { "type": { "const": "history_sync" } }
    },
    "SSEEventMetadataUpdated": {
      "type": "object",
      "description": "SSE: 세션 메타 갱신.",
      "required": ["type"],
      "additionalProperties": true,
