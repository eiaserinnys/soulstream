{
  "name": "@soulstream/serendipity-plugin",
  "version": "0.1.0",
  "description": "Soul plugin for Serendipity - renders Soul Server events in the Serendipity outliner",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles": "./dist/styles.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "soulstream",
    "serendipity",
    "plugin",
    "soul",
    "outliner"
  ],
  "author": "Dorothy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/eiaserinnys/soulstream.git",
    "directory": "packages/serendipity-plugin"
  }
}
