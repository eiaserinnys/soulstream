{
  "name": "@soulstream/soul-server-ts",
  "version": "0.0.1",
  "private": true,
  "description": "Soulstream soul-server (TS) — Codex 전담 노드 MVP. 옵션 D 비대칭 모델 단계 1.",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsup src/main.ts --format esm --target node20 --clean",
    "dev": "tsx src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@openai/codex-sdk": "^0.130.0",
    "@soulstream/wire-schema": "workspace:*",
    "dotenv": "^16.4.7",
    "fastify": "^5.1.0",
    "pino": "^9.5.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.13",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
