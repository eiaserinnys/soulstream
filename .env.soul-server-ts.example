# Soulstream TypeScript worker configuration

# Required
SOULSTREAM_NODE_ID=standalone-ts
SOULSTREAM_UPSTREAM_URL=ws://127.0.0.1:5200/ws/node
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/soulstream_test

# Local HTTP server
HOST=127.0.0.1
PORT=3105
ENVIRONMENT=development
LOG_LEVEL=info

# Auth
# Required when ENVIRONMENT=production.
AUTH_BEARER_TOKEN=

# Agent registry
AGENTS_CONFIG_PATH=config/agents.yaml

# Runtime files
INCOMING_FILE_DIR=.local/incoming

# Optional user display metadata advertised to the orchestrator
DASH_USER_NAME=
DASH_USER_PORTRAIT=

# Supervisor
SUPERVISOR_ENABLED=false
SUPERVISOR_EVENT_INGEST_ENABLED=false
