# Soulstream TypeScript worker configuration

# Required
SOULSTREAM_NODE_ID=standalone-ts
# Set to a TS node ID for legacy node hosting, or `orch` when the orchestrator hosts Y.Doc.
# `orch` is reserved and cannot be used as SOULSTREAM_NODE_ID.
BOARD_YJS_HOST_NODE_ID=standalone-ts
SOULSTREAM_UPSTREAM_URL=ws://127.0.0.1:5200/ws/node
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/soulstream_test

# Local HTTP server
HOST=127.0.0.1
PORT=3105
ENVIRONMENT=development
LOG_LEVEL=info

# Auth
# Required when ENVIRONMENT=production.
AUTH_BEARER_TOKEN=

# MCP post-start health contract
MCP_ENABLED=true
MCP_PATH=/mcp
MCP_REQUIRE_AUTH=false

# Agent registry
AGENTS_CONFIG_PATH=config/agents.yaml

# Runtime files
INCOMING_FILE_DIR=.local/incoming

# Optional user display metadata advertised to the orchestrator
DASH_USER_NAME=
DASH_USER_PORTRAIT=

# Supervisor
SUPERVISOR_ENABLED=false
SUPERVISOR_EVENT_INGEST_ENABLED=false
