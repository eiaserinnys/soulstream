{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "skipLibCheck": true,
    "paths": {
      "@seosoyoung/soul-ui": ["../packages/soul-ui/src/index.ts"],
      "@seosoyoung/soul-ui/*": ["../packages/soul-ui/src/*"],
      "@shared/*": ["../packages/soul-ui/src/shared/*"],
      "client/*": ["./client/*"]
    }
  },
  "include": ["client/**/*.ts", "client/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
