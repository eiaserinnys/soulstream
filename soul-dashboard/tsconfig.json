{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "paths": {
      "@shared/*": ["../packages/soul-ui/src/shared/*"],
      "@seosoyoung/soul-ui": ["../packages/soul-ui/src/index.ts"],
      "client/lib": ["./client/lib/index.ts"],
      "client/hooks/*": ["./client/hooks/*"],
      "client/components/*": ["./client/components/*"]
    }
  },
  "include": ["shared/**/*.ts", "server/**/*.ts", "client/**/*.ts", "client/**/*.tsx", "tools/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
