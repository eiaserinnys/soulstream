{
  "$schema": "https://raw.githubusercontent.com/nicholasyager/tauri-v2-schema/main/schema.json",
  "productName": "Soulstream",
  "version": "0.2.5",
  "identifier": "me.eiaserinnys.soulstream",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://*; img-src 'self' data:"
    },
    "windows": [
      {
        "label": "main",
        "url": "index.html",
        "create": false,
        "title": "Soulstream",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "devtools": true
      }
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE4NDVBQ0RCQkU4NUEyM0EKUldRNm9vVysyNnhGR05hWWtjZlRhdVdTbjZmZXZVdk40TkJkMmt3bDlXdGQzQUQxNXRFRlUxTmMK",
      "endpoints": [
        "https://eiaserinnys.me/tauri-update/update/soul-desktop?platform={{target}}&arch={{arch}}&bundle_type={{bundle_type}}&current_version={{current_version}}"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
