{
  "version": 1,
  "hostCapability": "board_yjs_host",
  "cardinality": {
    "zeroHostsStatus": 503,
    "twoHostsStatus": 503,
    "oneHostStatus": 200
  },
  "proxy": {
    "method": "POST",
    "route": "/api/markdown-documents",
    "upstreamPath": "/api/markdown-documents",
    "forwardedHeaders": [
      "authorization"
    ]
  },
  "directOperations": [
    {
      "operation": "create-markdown-document",
      "body": {
        "folderId": "folder-1",
        "title": "Note",
        "body": "Body",
        "x": 10,
        "y": 20,
        "documentId": "doc-1"
      }
    },
    {
      "operation": "upsert-session-board-item",
      "body": {
        "folderId": "folder-1",
        "container": { "containerKind": "task", "containerId": "task-1" },
        "sessionId": "session-1",
        "x": 30,
        "y": 40,
        "sourceTaskItemId": "item-1"
      }
    },
    {
      "operation": "upsert-task-board-item",
      "body": {
        "folderId": "folder-1",
        "boardItemId": "task:task-1",
        "taskId": "task-1",
        "title": "Task",
        "x": 50,
        "y": 60,
        "metadata": { "status": "open" }
      }
    },
    {
      "operation": "upsert-custom-view-board-item",
      "body": {
        "folderId": "folder-1",
        "container": { "containerKind": "folder", "containerId": "folder-1" },
        "boardItemId": "custom-view:view-1",
        "customViewId": "view-1",
        "title": "View",
        "html": "<p>View</p>",
        "revision": 2,
        "x": 70,
        "y": 80,
        "metadata": { "theme": "dark" }
      }
    },
    {
      "operation": "remove-task-board-item",
      "body": { "folderId": "folder-1", "boardItemId": "task:task-1" }
    },
    {
      "operation": "remove-board-item",
      "body": {
        "container": { "containerKind": "task", "containerId": "task-1" },
        "boardItemId": "session:session-1"
      }
    },
    {
      "operation": "update-board-item-position",
      "body": {
        "container": { "containerKind": "task", "containerId": "task-1" },
        "boardItemId": "session:session-1",
        "x": 90,
        "y": 100
      }
    },
    {
      "operation": "move-board-item-to-container",
      "body": {
        "boardItem": {
          "id": "session:session-1",
          "folderId": "folder-1",
          "containerKind": "folder",
          "containerId": "folder-1",
          "membershipKind": "primary",
          "sourceTaskItemId": null,
          "itemType": "session",
          "itemId": "session-1",
          "x": 30,
          "y": 40,
          "metadata": {}
        },
        "targetScope": {
          "folderId": "folder-1",
          "containerKind": "task",
          "containerId": "task-1"
        },
        "position": { "x": 110, "y": 120 }
      }
    },
    {
      "operation": "update-markdown-document",
      "body": {
        "container": { "containerKind": "folder", "containerId": "folder-1" },
        "documentId": "doc-1",
        "fields": { "title": "Updated", "body": "Updated body", "expectedVersion": 1 }
      }
    },
    {
      "operation": "delete-markdown-document",
      "body": {
        "container": { "containerKind": "folder", "containerId": "folder-1" },
        "documentId": "doc-1"
      }
    }
  ],
  "negativeAssertions": [
    "catalog_service.create_markdown_document is not called for markdown write routes"
  ]
}
