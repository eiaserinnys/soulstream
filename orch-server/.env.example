# soulstream-orch-server Configuration
#
# 환경별 설정 가이드
# - ENVIRONMENT=development → AUTH_BEARER_TOKEN, CORS_ALLOWED_ORIGINS 비워도 기동 가능 (편의)
# - ENVIRONMENT=production  → AUTH_BEARER_TOKEN, CORS_ALLOWED_ORIGINS 필수. 빈 값이면 startup 시 실패
#
# ─── 개발 환경 예시 ───
#   ENVIRONMENT=development
#   DATABASE_URL=postgresql://user:pass@localhost:5432/soulstream_dev
#   AUTH_BEARER_TOKEN=         # 비워두면 인증 우회 (로컬 편의)
#   CORS_ALLOWED_ORIGINS=      # 비워두면 CORSMiddleware가 아무 origin도 허용하지 않음
#                              # 브라우저 기반 개발이 필요하면 http://localhost:3000,http://localhost:5173 등으로 채움
#   JWT_SECRET=dev-secret-min-32-bytes-xxxxxxxxxxxxxx
#
# ─── 프로덕션 설정 (실제 값은 secret manager에서 주입) ───
#   ENVIRONMENT=production
#   DATABASE_URL=postgresql://user:pass@db:5432/soulstream_db
#   AUTH_BEARER_TOKEN=<soul-server .env와 동일한 64자+ 랜덤 토큰>
#   CORS_ALLOWED_ORIGINS=https://orchestrator.eiaserinnys.me,https://soul.eiaserinnys.me
#   JWT_SECRET=<32+ bytes 랜덤>
#   GOOGLE_CLIENT_ID=...
#   GOOGLE_CLIENT_SECRET=...
#   GOOGLE_CALLBACK_URL=/api/auth/google/callback
#   ALLOWED_EMAIL=...

# === 필수 ===
DATABASE_URL=postgresql://user:pass@host:5432/soulstream_db
ENVIRONMENT=development  # development | production | test

# === 인증 ===
# AUTH_BEARER_TOKEN=
# JWT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=
# ALLOWED_EMAIL=

# === CORS ===
# CORS_ALLOWED_ORIGINS=https://orchestrator.eiaserinnys.me,https://soul.eiaserinnys.me
# 프로덕션에서 필수. 빈 값이면 startup 시 RuntimeError로 즉시 실패함.
# CSV 또는 JSON 배열 형식 모두 수용: "https://a,https://b" 또는 '["https://a","https://b"]'

# === 서버 ===
# HOST=0.0.0.0
# PORT=3105
# NODE_NAME=orchestrator

# === 로깅 ===
# LOG_LEVEL=INFO
