{
  "name": "@soulstream/soul-server-ts",
  "version": "0.0.1",
  "private": true,
  "description": "Soulstream TypeScript execution worker for Claude, Codex, OpenAI Agents, MCP, and realtime services.",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsup src/main.ts --format esm --target node20 --clean",
    "dev": "tsx src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.140",
    "@fastify/websocket": "11.2.0",
    "@hocuspocus/extension-database": "3.4.4",
    "@hocuspocus/server": "3.4.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/agents": "0.11.4",
    "@openai/codex-sdk": "^0.130.0",
    "@soulstream/fractional-position": "workspace:*",
    "@soulstream/page-model": "workspace:*",
    "@soulstream/wire-schema": "workspace:*",
    "dotenv": "^16.4.7",
    "fastify": "^5.1.0",
    "pino": "^9.5.0",
    "postgres": "^3.4.9",
    "ws": "^8.18.0",
    "y-protocols": "1.0.6",
    "yaml": "^2.9.0",
    "yjs": "13.6.27",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.13",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
